<% if @chat.messages.count == 2 %>
  <%# First exchange: replace empty state with chat layout %>
  <%= turbo_stream.replace "empty-state" do %>
    <%= render "chat_layout", messages: @chat.messages.order(created_at: :asc) %>
  <% end %>
<% else %>
  <%= turbo_stream.append "messages" do %>
    <%= render "message", message: @user_message %>
  <% end %>
  <%= turbo_stream.append "messages" do %>
    <%= render "message", message: @assistant_message %>
  <% end %>
<% end %>
