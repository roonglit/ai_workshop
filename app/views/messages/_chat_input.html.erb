<%= form_with(model: form_message, url: messages_path) do |form| %>
  <%= form.hidden_field :role, value: "user" %>
  <div class="rounded-2xl shadow-lg border px-4 py-3 flex items-center gap-3" style="background-color: #FFFFFF; border-color: #E8E6E1;">
    <%= form.text_area :content,
      placeholder: "Message...",
      rows: 1,
      class: "chat-textarea flex-1 text-sm bg-transparent leading-relaxed",
      style: "color: #2F2F2E;",
      data: {
        chat_form_target: "textarea",
        action: "input->chat-form#autoResize keydown->chat-form#submitOnEnter"
      } %>
    <button type="submit" class="shrink-0 w-9 h-9 rounded-full flex items-center justify-center transition-colors cursor-pointer hover:opacity-80" style="background-color: #D4714E;">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="12" y1="19" x2="12" y2="5"/>
        <polyline points="5 12 12 5 19 12"/>
      </svg>
    </button>
  </div>
<% end %>
