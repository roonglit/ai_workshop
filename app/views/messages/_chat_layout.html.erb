<%# Top bar with clear button %>
<div class="px-4 pt-4 pb-0">
  <div class="max-w-3xl mx-auto flex justify-end">
    <%= button_to clear_all_messages_path, method: :delete,
      class: "group flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs tracking-wide transition-all duration-200 cursor-pointer",
      style: "color: #999; background: transparent;",
      data: { turbo_confirm: "Clear all messages?" },
      onmouseover: "this.style.color='#D4714E'; this.style.background='rgba(212,113,78,0.08)'",
      onmouseout: "this.style.color='#999'; this.style.background='transparent'" do %>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-200 group-hover:rotate-12">
        <path d="M3 6h18"/>
        <path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
        <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/>
      </svg>
      Clear
    <% end %>
  </div>
</div>

<div id="messages-container"
     class="flex-1 overflow-y-auto px-4 py-6"
     data-chat-form-target="messagesContainer">
  <div class="max-w-3xl mx-auto">
    <div id="messages">
      <%= render messages %>
    </div>
  </div>
</div>

<div class="pb-6 pt-2 px-4">
  <div class="max-w-3xl mx-auto">
    <%= render "chat_input", form_message: form_message %>
  </div>
</div>
