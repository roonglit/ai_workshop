<%
  hour = Time.current.hour
  greeting = if hour < 12
    "Good morning"
  elsif hour < 17
    "Good afternoon"
  else
    "Good evening"
  end
%>

<div id="empty-state" class="flex-1 flex flex-col items-center justify-center px-4">
  <div class="text-center mb-8">
    <h1 class="font-greeting text-4xl md:text-5xl font-semibold mb-2" style="color: #2F2F2E;"><%= greeting %></h1>
    <p class="text-base" style="color: #999;">How can I help you today?</p>
  </div>
  <div class="w-full max-w-3xl">
    <%= render "chat_input", form_message: form_message %>
  </div>
</div>
